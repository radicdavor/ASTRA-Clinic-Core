APP_ENV=production
ENVIRONMENT=production

# Generate strong unique values before deployment. Do not copy development values.
POSTGRES_DB=astra_clinic
POSTGRES_USER=astra_app
POSTGRES_PASSWORD=<strong-database-password>
DATABASE_URL=postgresql+psycopg://astra_app:<strong-database-password>@db:5432/astra_clinic
JWT_SECRET=<at-least-32-random-characters>
ACCESS_TOKEN_MINUTES=480
BROWSER_SESSION_MINUTES=480
SESSION_COOKIE_NAME=astra_session
CSRF_COOKIE_NAME=astra_csrf
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# Canonical browser deployment: one public origin; reverse proxy /api and /auth to FastAPI.
BROWSER_PUBLIC_ORIGIN=https://conceptnura.com
CORS_ORIGINS=https://conceptnura.com
CORS_ORIGIN_REGEX=

DEBUG=false
RELOAD=false
DEMO_MODE=false
DEMO_SEED_ENABLED=false
DEMO_PERSONA_SWITCHER_ENABLED=false
AUTO_CREATE_DEFAULT_ADMIN=false
REAL_DATA_ALLOWED=true

# Configure real providers only after explicit authorization and operational readiness.
FISCALIZATION_MODE=production
OCR_PROVIDER_MODE=production
REMINDER_PROVIDER_MODE=production
AI_SUMMARY_PROVIDER_MODE=production

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_DIAGNOSIS_SUGGESTIONS_ENABLED=false
AI_DIAGNOSIS_SUGGESTIONS_PRODUCTION_AUTHORIZED=false

# Empty means same-origin relative /api and /auth requests.
VITE_API_BASE_URL=
