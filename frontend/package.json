{
  "name": "astra-clinic-core-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "test": "node --test scripts/program2-contract.test.mjs && vitest run",
    "e2e": "playwright test",
    "e2e:db": "node scripts/run-db-backed-e2e.mjs",
    "smoke": "playwright test -c playwright.config.ts e2e/semantic-smoke.spec.ts",
    "program1:evaluation-readiness": "node scripts/program1-evaluation-readiness.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  }
}
