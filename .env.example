POSTGRES_DB=astra_clinic
POSTGRES_USER=astra
POSTGRES_PASSWORD=astra
DATABASE_URL=postgresql+psycopg://astra:astra@db:5432/astra_clinic
APP_ENV=development
ENVIRONMENT=local
DEBUG=false
RELOAD=false
DEMO_MODE=true
DEMO_SEED_ENABLED=false
DEMO_PERSONA_SWITCHER_ENABLED=true
AUTO_CREATE_DEFAULT_ADMIN=false
REAL_DATA_ALLOWED=false
FISCALIZATION_MODE=noop
OCR_PROVIDER_MODE=local_demo
REMINDER_PROVIDER_MODE=local_demo
AI_SUMMARY_PROVIDER_MODE=local_deterministic
JWT_SECRET=change-this-local-secret
ACCESS_TOKEN_MINUTES=480
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Development default accepts localhost and private LAN origins. In production,
# set CORS_ORIGIN_REGEX empty and use explicit CORS_ORIGINS.
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|10\.[0-9]+\.[0-9]+\.[0-9]+|192\.168\.[0-9]+\.[0-9]+|172\.(1[6-9]|2[0-9]|3[0-1])\.[0-9]+\.[0-9]+)(:[0-9]+)?$
# Leave empty to make the browser call http://<current-host>:8000.
# This is the recommended local LAN setup: open http://<computer-LAN-IP>:5173
# from another device and the frontend will call http://<computer-LAN-IP>:8000.
VITE_API_BASE_URL=
VITE_APP_ENV=development
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_DIAGNOSIS_SUGGESTIONS_ENABLED=false
AI_DIAGNOSIS_SUGGESTIONS_PRODUCTION_AUTHORIZED=false
